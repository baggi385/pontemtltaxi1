// Dynamic traffic indicator
function updateTraffic(){
  var now = new Date();
  var h = now.getHours();
  var d = now.getDay();
  var box = document.getElementById('traffic-box');
  var timeEl = document.getElementById('traffic-time');
  if(!box) return;

  var status, time, color, icon;
  if(d===5 && h>=15 && h<20){
    status='Vendredi soir \u2014 trafic tr\u00e8s dense'; time='40-60min'; color='#ef4444'; icon='\uD83D\uDD34';
  } else if(d>=1 && d<=5 && h>=7 && h<9){
    status='Heure de pointe matinale'; time='35-50min'; color='#f97316'; icon='\uD83D\uDFE0';
  } else if(d>=1 && d<=5 && h>=16 && h<19){
    status='Heure de pointe en soir\u00e9e'; time='35-45min'; color='#f97316'; icon='\uD83D\uDFE0';
  } else if(d===0||d===6){
    status='Weekend \u2014 trafic l\u00e9ger'; time='20-30min'; color='#22c55e'; icon='\uD83D\uDFE2';
  } else {
    status='Trafic normal'; time='20-30min'; color='#22c55e'; icon='\uD83D\uDFE2';
  }

  if(timeEl) timeEl.textContent = time;
  box.innerHTML = icon + ' <strong style="color:'+color+'">' + status + '</strong> \u2014 Temps estim\u00e9: ' + time
    + '<br><small style="opacity:.6">Mis \u00e0 jour selon l\u2019heure actuelle \u00b7 Pr\u00e9voir 2h30 avant le vol</small>';
}
updateTraffic();
